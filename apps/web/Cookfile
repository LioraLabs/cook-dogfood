import contracts //contracts
import menugen //tools/menugen

probe web:tools
    tools { node, pnpm }

probe pnpm:packages
    ingredients "pnpm-workspace.yaml" "packages/*/package.json" "app/package.json"
    json {
        node -e 'const fs = require("fs"); const dirs = fs.readdirSync("packages").map(d => "packages/" + d).concat(["app"]); const pkgs = dirs.filter(d => fs.existsSync(d + "/package.json")).map(d => { const pj = JSON.parse(fs.readFileSync(d + "/package.json", "utf8")); return { name: pj.name, dir: d }; }); process.stdout.write(JSON.stringify(pkgs));'
    }

recipe deps
    ingredients "package.json" "pnpm-lock.yaml" "pnpm-workspace.yaml" "packages/*/package.json" "app/package.json"
    seal web:tools
    cook "build/pnpm-install.stamp" { pnpm install --frozen-lockfile --silent && mkdir -p build && { sha256sum pnpm-lock.yaml; pnpm exec tsc --version; pnpm exec esbuild --version; } > $<out> } local

recipe client
    ingredients "packages/client/tsconfig.json" "packages/client/package.json"
    seal web:tools
    cook "packages/client/src/menuClient.ts" { mkdir -p packages/client/src && cp $<contracts.gen> $<out> }
    cook "packages/client/dist/menuClient.js" "packages/client/dist/menuClient.d.ts" { : $<deps> $<file:packages/client/tsconfig.json> $<file:packages/client/package.json> && pnpm --filter @plateboard/client exec tsc -p . }

recipe ui
    ingredients "packages/ui/src/*.ts" "packages/ui/tsconfig.json" "packages/ui/package.json"
    seal web:tools
    cook "packages/ui/dist/board.js" "packages/ui/dist/board.d.ts" { : $<client> $<deps> && pnpm --filter @plateboard/ui exec tsc -p . }

recipe menudata
    cook "app/src/menu.json" { mkdir -p app/src && cp $<menugen.menu> $<out> }

recipe bundle
    ingredients "app/src/main.ts" "app/tsconfig.json" "app/package.json"
    seal web:tools
    cook "app/dist/bundle.js" { : $<ui> $<menudata> $<deps> && pnpm --filter @plateboard/app exec esbuild src/main.ts --bundle --format=esm --outfile=dist/bundle.js --log-level=warning }

recipe typecheck
    ingredients pnpm:packages
    seal web:tools
    cook "build/typecheck/$<in.dir>.stamp" { : $<client> $<ui> $<menudata> $<deps> && mkdir -p "$(dirname $<out>)" && pnpm --filter "$<in.name>" exec tsc -p . --noEmit && echo ok > $<out> }

recipe smoke
    ingredients "app/test/smoke.mjs"
    test { : $<bundle> && node app/test/smoke.mjs }
